# ============================================================
# Copy this file to `.env.local` and fill in the values.
# `.env.local` is git-ignored, so your secrets stay private.
# ============================================================

# --- Supabase (required) ---------------------------------------------------
# From: Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — SERVER ONLY, never expose in the browser.
# Needed for: OTP phone verification, SMS alerts, admin jobs.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- SMS gateway (optional — site works fine without it) --------------------
# Leave SMS_API_KEY empty to disable all SMS (OTP is skipped, alerts are skipped).
# Provider: "smsnetbd" (sms.net.bd / Alpha SMS) or "bulksmsbd" (bulksmsbd.net)
SMS_PROVIDER=smsnetbd
SMS_API_KEY=
# Sender ID: only needed for bulksmsbd (they give you one after registration)
SMS_SENDER_ID=
# Hard monthly cap. 1800 SMS x ~0.30 Tk = ~540 Tk (~$4.50), under the $5 budget.
SMS_MONTHLY_CAP=1800

# --- Daily cron (optional — powers eligibility reminders + auto-expiring requests) ---
# Any random string. Vercel automatically sends it as a Bearer token when
# this env var is set on the project, so the /api/cron/daily route is
# only reachable by Vercel's own scheduler, not the public internet.
CRON_SECRET=

# --- Web push notifications (optional, free — complements SMS) --------------
# Generate a keypair once with:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# The public key is safe to expose (it's sent to the browser); the private
# key must stay server-only.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# --- Site ------------------------------------------------------------------
# Your deployed URL (used in SMS links + SEO). No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Volunteer helpline phone shown in the footer for people who can't use the site
NEXT_PUBLIC_HELPLINE_PHONE=01700000000
